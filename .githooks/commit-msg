#!/usr/bin/env bash

set -euo pipefail

commit_msg_file="$1"
commit_msg="$(head -n1 "$commit_msg_file")"

# <type>(<scope>)?: <description>
pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .{1,}$'

if [[ ! "$commit_msg" =~ $pattern ]]; then
  echo "Erro: mensagem de commit invalida."
  echo "Use o padrao Conventional Commits:"
  echo "  <type>(<scope opcional>): <descricao>"
  echo
  echo "Exemplos:"
  echo "  feat(home): adiciona secao de projetos"
  echo "  fix(i18n): corrige troca de idioma"
  exit 1
fi
